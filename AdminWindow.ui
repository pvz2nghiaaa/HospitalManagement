      <property name="styleSheet">
       <string notr="true">QFrame#frameDashboard {
    background-color: rgb(30, 41, 59);
    border-radius: 10px;
}
QLabel {
    color: rgb(241, 245, 249);
}
QLineEdit, QComboBox {
    background-color: rgb(15, 23, 42);
    border: 1px solid rgb(71, 85, 105);
    border-radius: 6px;
    color: rgb(241, 245, 249);
    padding: 4px 8px;
}
QLineEdit:focus, QComboBox:focus {
    border: 1px solid rgb(6, 182, 212);
}
QTableWidget {
    background-color: rgb(15, 23, 42);
    color: rgb(226, 232, 240);
    gridline-color: rgb(51, 65, 85);
    border: 1px solid rgb(51, 65, 85);
    border-radius: 8px;
}
QHeaderView::section {
    background-color: rgb(30, 41, 59);
    color: rgb(6, 182, 212);
    padding: 6px;
    font-weight: bold;
    border: none;
    border-bottom: 2px solid rgb(51, 65, 85);
}
QPushButton {
    background-color: rgb(71, 85, 105);
    color: white;
    border: none;
    border-radius: 6px;
    padding: 6px 14px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: rgb(51, 65, 85);
}
QPushButton#btnSearch, QPushButton#btnAddStaff {
    background-color: rgb(6, 182, 212);
}
QPushButton#btnSearch:hover, QPushButton#btnAddStaff:hover {
    background-color: rgb(8, 145, 178);
}
QPushButton#btnDeleteStaff {
    background-color: rgb(239, 68, 68);
}
QPushButton#btnDeleteStaff:hover {
    background-color: rgb(220, 38, 38);
}</string>
