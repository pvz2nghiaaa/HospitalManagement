      <property name="styleSheet">
       <string notr="true">QFrame#frameDashboard_2 {
    background-color: rgb(30, 41, 59);
    border-radius: 10px;
}
QLabel {
    color: rgb(241, 245, 249);
}
QGroupBox {
    border: 1px solid rgb(51, 65, 85);
    border-radius: 8px;
    margin-top: 12px;
    font-weight: bold;
    color: rgb(6, 182, 212);
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 8px;
    left: 10px;
}
QTableWidget {
    background-color: rgb(15, 23, 42);
    color: rgb(226, 232, 240);
    gridline-color: rgb(51, 65, 85);
    border: 1px solid rgb(51, 65, 85);
    border-radius: 8px;
}
QHeaderView::section {
    background-color: rgb(30, 41, 59);
    color: rgb(6, 182, 212);
    padding: 6px;
    font-weight: bold;
    border: none;
    border-bottom: 2px solid rgb(51, 65, 85);
}
QPushButton {
    background-color: rgb(15, 23, 42);
    color: rgb(241, 245, 249);
    border: 1px solid rgb(51, 65, 85);
    border-radius: 6px;
    font-weight: bold;
    padding: 8px;
}
QPushButton:hover {
    background-color: rgb(6, 182, 212);
    color: white;
    border-color: rgb(6, 182, 212);
}</string>
