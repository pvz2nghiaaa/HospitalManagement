      <property name="styleSheet">
       <string notr="true">QFrame#frameDashboard_2 {
    background-color: rgb(30, 41, 59);
    border-radius: 10px;
}
QLabel {
    color: rgb(241, 245, 249);
}
QLineEdit, QComboBox, QDateEdit {
    background-color: rgb(15, 23, 42);
    border: 1px solid rgb(71, 85, 105);
    border-radius: 6px;
    color: rgb(241, 245, 249);
    padding: 4px 8px;
}
QLineEdit:focus, QComboBox:focus, QDateEdit:focus {
    border: 1px solid rgb(6, 182, 212);
}
QTextEdit {
    background-color: rgb(15, 23, 42);
    border: 1px solid rgb(71, 85, 105);
    border-radius: 6px;
    color: rgb(241, 245, 249);
}
QTableWidget {
    background-color: rgb(15, 23, 42);
    color: rgb(226, 232, 240);
    gridline-color: rgb(51, 65, 85);
    border: 1px solid rgb(51, 65, 85);
    border-radius: 8px;
}
QHeaderView::section {
    background-color: rgb(30, 41, 59);
    color: rgb(6, 182, 212);
    padding: 6px;
    font-weight: bold;
    border: none;
    border-bottom: 2px solid rgb(51, 65, 85);
}
QTabWidget::pane {
    border: 1px solid rgb(51, 65, 85);
    background: rgb(30, 41, 59);
    border-radius: 6px;
}
QTabBar::tab {
    background: rgb(15, 23, 42);
    color: rgb(148, 163, 184);
    padding: 6px 12px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    margin-right: 2px;
}
QTabBar::tab:selected, QTabBar::tab:hover {
    background: rgb(30, 41, 59);
    color: white;
}
QTabBar::tab:selected {
    border-bottom: 2px solid rgb(6, 182, 212);
}
QPushButton {
    background-color: rgb(71, 85, 105);
    color: white;
    border: none;
    border-radius: 6px;
    padding: 6px 14px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: rgb(51, 65, 85);
}
QPushButton#btnSearch_4, QPushButton#btnSaveDiagnosis, QPushButton#pushButton_4 {
    background-color: rgb(6, 182, 212);
}
QPushButton#btnSearch_4:hover, QPushButton#btnSaveDiagnosis:hover, QPushButton#pushButton_4:hover {
    background-color: rgb(8, 145, 178);
}
QPushButton#btnComplete {
    background-color: rgb(34, 197, 94);
}
QPushButton#btnComplete:hover {
    background-color: rgb(22, 163, 74);
}</string>
