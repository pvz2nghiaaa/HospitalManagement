}
QLineEdit:focus, QComboBox:focus, QDateEdit:focus {
    border: 1px solid rgb(6, 182, 212);
}
QTableWidget {
    background-color: rgb(15, 23, 42);
    color: rgb(226, 232, 240);
    gridline-color: rgb(51, 65, 85);
    border: 1px solid rgb(51, 65, 85);
    border-radius: 8px;
}
QHeaderView::section {
    background-color: rgb(30, 41, 59);
    color: rgb(6, 182, 212);
    padding: 6px;
    font-weight: bold;
    border: none;
    border-bottom: 2px solid rgb(51, 65, 85);
}
QGroupBox {
    border: 1px solid rgb(51, 65, 85);
    border-radius: 8px;
    margin-top: 12px;
    font-weight: bold;
    color: rgb(6, 182, 212);
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 8px;
    left: 10px;
}
QPushButton {
    background-color: rgb(71, 85, 105);
    color: white;
    border: none;
    border-radius: 6px;
    padding: 6px 14px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: rgb(51, 65, 85);
}
QPushButton#btnSearch_5, QPushButton#btnPrintRecord {
    background-color: rgb(6, 182, 212);
}
QPushButton#btnSearch_5:hover, QPushButton#btnPrintRecord:hover {
    background-color: rgb(8, 145, 178);
}
QPushButton#btnCloseRecord {
    background-color: rgb(239, 68, 68);
}
QPushButton#btnCloseRecord:hover {
    background-color: rgb(220, 38, 38);
}</string>
