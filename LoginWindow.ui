      <string notr="true">QPushButton#btnLogin {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgb(6, 182, 212), stop:1 rgb(37, 99, 235));
    color: white;
    font-weight: bold;
    border: none;
    border-radius: 6px;
    padding: 10px;
    font-size: 15px;
}
QPushButton#btnLogin:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgb(8, 145, 178), stop:1 rgb(29, 78, 216));
}
QPushButton#btnLogin:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgb(21, 94, 117), stop:1 rgb(30, 58, 138));
}</string>
